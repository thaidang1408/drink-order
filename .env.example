# Server

NODE_ENV=development

PORT=8080

HOST=0.0.0.0



# Database (MySQL)

DATABASE_URL="mysql://root:password@localhost:3306/qr_ordering"



# Frontend URL (used for QR code generation)

FRONTEND_URL=http://localhost:5173



# CORS

CORS_ORIGIN=http://localhost:5173



# Socket.IO

SOCKET_CORS_ORIGIN=http://localhost:5173



# JWT (production: at least 32 characters, no demo defaults)

JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

JWT_EXPIRES_IN=7d



# Docker / deploy scripts — set true only for first-time demo seed

RUN_DB_SEED=false



# Cloudinary (optional - required for image upload)

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

CLOUDINARY_FOLDER=qr-ordering


{
  "name": "qr-ordering-api",
  "version": "1.0.0",
  "description": "SaaS QR Ordering System - Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "start": "node src/server.js",
    "port:free": "node scripts/free-port.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:setup": "prisma db push && node prisma/seed.js",
    "db:studio": "prisma studio",
    "build": "npm run db:generate && npm run build --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "start:prod": "node src/server.js",
    "deploy:docker": "powershell -ExecutionPolicy Bypass -File scripts/deploy-docker.ps1",
    "deploy:local": "powershell -ExecutionPolicy Bypass -File scripts/deploy-local.ps1",
    "deploy:wifi": "powershell -ExecutionPolicy Bypass -File scripts/deploy-wifi.ps1",
    "deploy:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloudflare.ps1",
    "deploy:tunnel:lt": "powershell -ExecutionPolicy Bypass -File scripts/deploy-localtunnel.ps1"
  },
  "keywords": [
    "qr-ordering",
    "saas",
    "express",
    "prisma"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "3.0.3",
    "cloudinary": "2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.3",
    "morgan": "^1.10.0",
    "multer": "2.2.0",
    "qrcode": "1.5.4",
    "socket.io": "^4.8.1",
    "zod": "4.4.3",
    "prisma": "^6.9.0"
  },
  "devDependencies": {
    "kill-port": "2.0.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
